{
  "name": "shadcn-ui-playground",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "hooks:install": "git config core.hooksPath .githooks",
    "workflow:check-docs": "node scripts/workflow/check-workflow-docs.mjs",
    "workflow:check-docs:staged": "node scripts/workflow/check-workflow-docs.mjs --staged",
    "workflow:check-commit-msg": "node scripts/workflow/check-commit-message.mjs",
    "tree:build": "tsx scripts/build-file-tree.ts --dry-run --pretty --out .cache/file-tree/manifest.json",
    "tree:refresh": "tsx scripts/build-file-tree.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "auth:schema": "better-auth generate --config ./lib/auth/index.ts --output drizzle/schema.ts --yes"
  },
